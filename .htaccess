Options -Indexes +FollowSymLinks
RewriteEngine On
RewriteBase /

# 1. Handle trailing slashes (Redirect to no-slash for files)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^(.+)/$
RewriteRule ^ %1 [R=301,L]

# 2. External redirect: Remove index.html
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+/)?index\.html\ [NC]
RewriteRule ^(.+/)?index\.html$ /%1 [R=301,L]

# 3. External redirect: Remove .html extension
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 4. Internal rewrite: Serve .html file if it exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ $1.html [L]

DirectoryIndex index.html
