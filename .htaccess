Options -Indexes +FollowSymLinks
RewriteEngine On

# 1. Remove index.html (External Redirect)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+/)?index\.html\ [NC]
RewriteRule ^(.+/)?index\.html$ /%1 [R=301,L]

# 2. Remove .html extension (External Redirect)
# The [NC,L] ensures we stop here and let the browser update the URL
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3. Handle trailing slashes (Redirect folder/ to folder)
# Only if it's NOT a real directory to avoid Apache loops
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^(.+)/$
RewriteRule ^ %1 [R=301,L]

# 4. Internal rewrite: Map clean URL to .html file
# This happens behind the scenes (the user doesn't see .html)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ $1.html [L]

DirectoryIndex index.html